---
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import { SITE, HOME } from "@consts";
import Introduction from "@components/HomePage/Introduction.astro";
import BlogCollection from "@components/HomePage/BlogCollection.astro";
import WorkCollection from "@components/HomePage/WorkCollection.astro";
import ProjectCollection from "@components/HomePage/ProjectCollection.astro";
import LetsConnect from "@components/HomePage/LetsConnect.astro";

---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
    <Container>
        <h4 class="animate font-semibold text-black dark:text-white">
            Hi, I'm { SITE.SHORT_NAME } <span class="text-xl">👋🏻</span>
        </h4>
        <div class="space-y-16">
            <Introduction/>
            <BlogCollection/>
            <WorkCollection/>
            <ProjectCollection/>
            <LetsConnect/>
        </div>
    </Container>
</PageLayout>
